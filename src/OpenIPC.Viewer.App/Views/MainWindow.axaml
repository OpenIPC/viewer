<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenIPC.Viewer.App.ViewModels"
        xmlns:views="using:OpenIPC.Viewer.App.Views"
        x:Class="OpenIPC.Viewer.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="OpenIPC Viewer"
        Icon="/Assets/openipc-logo.png"
        Width="1200" Height="780"
        MinWidth="900" MinHeight="600"
        Background="{StaticResource Bg1Brush}">

  <Window.KeyBindings>
    <!-- F11 toggles the kiosk fullscreen; Esc only exits it (no-op otherwise). -->
    <KeyBinding Gesture="F11" Command="{Binding ToggleKioskCommand}" />
    <KeyBinding Gesture="Escape" Command="{Binding ExitKioskCommand}" />
  </Window.KeyBindings>

  <views:MainView />

</Window>
