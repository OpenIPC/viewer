<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenIPC.Viewer.App.ViewModels"
             xmlns:controls="using:OpenIPC.Viewer.App.Controls"
             xmlns:input="using:Avalonia.Input"
             xmlns:svc="using:OpenIPC.Viewer.App.Services"
             x:Class="OpenIPC.Viewer.App.Views.Pages.SingleCameraPage"
             x:DataType="vm:SingleCameraPageViewModel">

  <Grid RowDefinitions="Auto,*,Auto,Auto">

    <!-- Header. Hidden in landscape fullscreen — only the video row stays. -->
    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,12"
          IsVisible="{Binding !IsFullscreen}">
      <Button Grid.Column="0"
              Content="{Binding [Common.Back], Source={x:Static svc:Localizer.Instance}}"
              Command="{Binding BackCommand}"
              Background="Transparent"
              BorderBrush="{StaticResource BorderMediumBrush}"
              BorderThickness="1"
              CornerRadius="6"
              Padding="10,6"
              Foreground="{StaticResource TextPrimaryBrush}" />
      <StackPanel Grid.Column="1" Spacing="2" Margin="16,0,0,0" VerticalAlignment="Center">
        <TextBlock Text="{Binding CameraName}"
                   FontSize="{StaticResource FontSizeLg}"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}" />
        <TextBlock Text="{Binding HostLabel}"
                   FontFamily="{StaticResource FontMono}"
                   FontSize="{StaticResource FontSizeSm}"
                   Foreground="{StaticResource TextSecondaryBrush}" />
      </StackPanel>
    </Grid>

    <!-- Video + overlays. ClipToBounds keeps zoomed frames inside this row.
         RenderTransform binds ZoomLevel from the VM (1.0..4.0 digital zoom).
         Code-behind attaches Holding / DoubleTapped / Pinch / swipe handlers
         to this grid. -->
    <Grid Grid.Row="1" Name="VideoArea" ClipToBounds="True">
      <controls:RtspVideoView Name="VideoView" Session="{Binding Session}"
                              RenderTransformOrigin="0.5,0.5">
        <controls:RtspVideoView.RenderTransform>
          <ScaleTransform ScaleX="{Binding ZoomLevel}" ScaleY="{Binding ZoomLevel}" />
        </controls:RtspVideoView.RenderTransform>
        <controls:RtspVideoView.GestureRecognizers>
          <input:PinchGestureRecognizer />
        </controls:RtspVideoView.GestureRecognizers>
      </controls:RtspVideoView>

      <!-- Top-left LIVE badge -->
      <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12"
              Background="{StaticResource DangerBrush}"
              CornerRadius="3"
              Padding="6,2"
              IsVisible="{Binding Session, Converter={x:Static ObjectConverters.IsNotNull}}">
        <TextBlock Text="LIVE" FontFamily="{StaticResource FontMono}" FontSize="10" Foreground="White" />
      </Border>

      <!-- Top-right resolution/codec -->
      <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12"
              Background="#80000000"
              CornerRadius="3"
              Padding="6,2"
              IsVisible="{Binding ShowTelemetryBadges}">
        <TextBlock FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}">
          <Run Text="{Binding Telemetry.Width}" /><Run Text="x" /><Run Text="{Binding Telemetry.Height}" /><Run Text=" " /><Run Text="{Binding Telemetry.Codec}" />
        </TextBlock>
      </Border>

      <!-- Bottom-left fps -->
      <Border HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="12"
              Background="#80000000"
              CornerRadius="3"
              Padding="6,2"
              IsVisible="{Binding ShowTelemetryBadges}">
        <TextBlock FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}">
          <Run Text="{Binding Telemetry.Fps, StringFormat={}{0:F0} fps}" />
        </TextBlock>
      </Border>

      <!-- Bottom-right frames -->
      <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="12"
              Background="#80000000"
              CornerRadius="3"
              Padding="6,2"
              IsVisible="{Binding ShowTelemetryBadges}">
        <TextBlock FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}">
          <Run Text="{Binding Telemetry.FramesDecoded}" /><Run Text=" frames" />
        </TextBlock>
      </Border>

      <!-- Top-strip error banner. Visible only when there's an ErrorMessage AND
           we're not showing the full-area Disconnected overlay — that covers
           failures with a louder UI. The strip stays for non-stream errors
           (snapshot / recording / copy / save-as) raised while the stream is
           still alive. -->
      <Border HorizontalAlignment="Stretch" VerticalAlignment="Top"
              Background="{StaticResource DangerBrush}"
              Padding="12,8"
              IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
        <TextBlock Text="{Binding ErrorMessage}" Foreground="White" />
      </Border>

      <!-- PTZ overlay (joystick + presets), bottom-right, only for PTZ cams.
           Long-press on the video toggles IsPtzOverlayVisible to free up
           screen real estate on mobile while keeping it pinned on desktop. -->
      <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom"
                  Margin="0,0,12,48" Spacing="10"
                  IsVisible="{Binding IsPtzPanelVisible}">
        <controls:PtzJoystick Controller="{Binding Ptz}" HorizontalAlignment="Right" />

        <Border Background="#90000000" CornerRadius="6" Padding="8" MaxWidth="280">
          <StackPanel Spacing="6">
            <ItemsControl ItemsSource="{Binding Presets}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="2" ColumnDefinitions="Auto,Auto">
                    <Button Grid.Column="0"
                            Content="{Binding Name}"
                            Padding="8,4"
                            Background="{StaticResource Bg2Brush}"
                            Foreground="White"
                            CornerRadius="4"
                            FontSize="11"
                            Command="{Binding $parent[ItemsControl].((vm:SingleCameraPageViewModel)DataContext).GotoPresetCommand}"
                            CommandParameter="{Binding}" />
                    <Button Grid.Column="1"
                            Padding="6,4"
                            Background="Transparent"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Command="{Binding $parent[ItemsControl].((vm:SingleCameraPageViewModel)DataContext).RemovePresetCommand}"
                            CommandParameter="{Binding}"
                            ToolTip.Tip="{Binding [CameraPage.Tooltip.RemovePreset], Source={x:Static svc:Localizer.Instance}}">
                      <Path Classes="lucide" Data="{StaticResource IconClose}"
                            Stroke="{StaticResource TextSecondaryBrush}"
                            Width="12" Height="12" />
                    </Button>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Grid ColumnDefinitions="*,Auto" Margin="2,4,2,2">
              <TextBox Grid.Column="0"
                       Text="{Binding NewPresetName, Mode=TwoWay}"
                       PlaceholderText="{Binding [CameraPage.Preset.Placeholder], Source={x:Static svc:Localizer.Instance}}"
                       FontSize="11"
                       Padding="6,4"
                       Margin="0,0,4,0" />
              <Button Grid.Column="1"
                      Content="{Binding [CameraPage.Preset.Save], Source={x:Static svc:Localizer.Instance}}"
                      Command="{Binding SavePresetCommand}"
                      Padding="8,4"
                      Background="{StaticResource AccentBrush}"
                      Foreground="White"
                      CornerRadius="4"
                      FontSize="11" />
            </Grid>
          </StackPanel>
        </Border>
      </StackPanel>

      <!-- Connecting overlay. Full-area dim with a centered spinner. Rendered
           late so it floats on top of LIVE / telemetry badges during connect /
           reconnect. -->
      <Border IsVisible="{Binding IsConnecting}"
              Background="#A0000000">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="14">
          <ProgressBar IsIndeterminate="True" Width="180" />
          <TextBlock Text="{Binding [Stream.Connecting], Source={x:Static svc:Localizer.Instance}}"
                     Foreground="White"
                     FontSize="{StaticResource FontSizeMd}"
                     HorizontalAlignment="Center" />
        </StackPanel>
      </Border>

      <!-- Disconnected overlay. Failure UI — headline, server-supplied error,
           and a Retry button that re-runs the full Activate path. -->
      <Border IsVisible="{Binding IsFailed}"
              Background="#A0000000">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12" MaxWidth="420">
          <TextBlock Text="{Binding [Stream.Disconnected], Source={x:Static svc:Localizer.Instance}}"
                     Foreground="White"
                     FontSize="{StaticResource FontSizeLg}"
                     FontWeight="SemiBold"
                     HorizontalAlignment="Center" />
          <TextBlock Text="{Binding ErrorMessage}"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     FontSize="{StaticResource FontSizeBase}"
                     TextWrapping="Wrap"
                     HorizontalAlignment="Center"
                     TextAlignment="Center"
                     IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
          <Button Content="{Binding [Common.Retry], Source={x:Static svc:Localizer.Instance}}"
                  Command="{Binding RetryCommand}"
                  Padding="18,8"
                  Background="{StaticResource AccentBrush}"
                  Foreground="White"
                  CornerRadius="6"
                  HorizontalAlignment="Center"
                  Margin="0,4,0,0" />
        </StackPanel>
      </Border>
    </Grid>

    <!-- Majestic Config panel (Phase 5) — only for OpenIPC-Majestic cameras -->
    <Border Grid.Row="2"
            Margin="0,12,0,0"
            Padding="14,10"
            Background="{StaticResource Bg2Brush}"
            BorderBrush="{StaticResource BorderWeakBrush}"
            BorderThickness="1"
            CornerRadius="8">
      <Border.IsVisible>
        <MultiBinding Converter="{x:Static BoolConverters.And}">
          <Binding Path="IsMajestic" />
          <Binding Path="!IsFullscreen" />
        </MultiBinding>
      </Border.IsVisible>
      <StackPanel Spacing="8">

        <!-- Title row -->
        <Grid ColumnDefinitions="Auto,*,Auto">
          <TextBlock Grid.Column="0" Text="Majestic"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     VerticalAlignment="Center" />
          <TextBlock Grid.Column="2"
                     FontSize="11"
                     Foreground="{StaticResource TextTertiaryBrush}"
                     VerticalAlignment="Center">
            <Run Text="{Binding MajesticInfo.Model, FallbackValue='?'}" />
            <Run Text="·" />
            <Run Text="{Binding MajesticInfo.FirmwareVersion, FallbackValue='?'}" />
            <Run Text="·" />
            <Run Text="{Binding [CameraPage.Majestic.NightPrefix], Source={x:Static svc:Localizer.Instance}}" />
            <Run Text="{Binding CurrentNightMode}" />
          </TextBlock>
        </Grid>

        <!-- Editable knobs. WrapPanel of label+control pairs so the five knobs
             reflow across lines on a narrow viewport instead of running off the
             right edge of a single 10-column row. -->
        <WrapPanel Orientation="Horizontal" ItemSpacing="14" LineSpacing="8">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="{Binding [CameraPage.Majestic.Resolution], Source={x:Static svc:Localizer.Instance}}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
            <ComboBox ItemsSource="{Binding ResolutionOptions}" SelectedItem="{Binding DraftResolution, Mode=TwoWay}" MinWidth="120" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="{Binding [CameraPage.Majestic.Codec], Source={x:Static svc:Localizer.Instance}}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
            <ComboBox ItemsSource="{Binding CodecOptions}" SelectedItem="{Binding DraftCodec, Mode=TwoWay}" MinWidth="80" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="{Binding [CameraPage.Majestic.Fps], Source={x:Static svc:Localizer.Instance}}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
            <ComboBox ItemsSource="{Binding FpsOptions}" SelectedItem="{Binding DraftFps, Mode=TwoWay}" MinWidth="70" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="{Binding [CameraPage.Majestic.Bitrate], Source={x:Static svc:Localizer.Instance}}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
            <NumericUpDown Value="{Binding DraftBitrate, Mode=TwoWay}" Minimum="256" Maximum="16384" Increment="256" FormatString="0" MinWidth="100" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="{Binding [CameraPage.Majestic.Profile], Source={x:Static svc:Localizer.Instance}}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
            <ComboBox ItemsSource="{Binding ProfileOptions}" SelectedItem="{Binding DraftProfile, Mode=TwoWay}" MinWidth="100" />
          </StackPanel>
        </WrapPanel>

        <!-- RTMP push (Phase 11.7): checkbox + URL. Empty URL with toggle on
             is intentionally allowed — Majestic accepts it as "off". -->
        <Grid ColumnDefinitions="Auto,Auto,*" Margin="0,0,0,0">
          <CheckBox Grid.Column="0"
                    IsChecked="{Binding DraftRtmpEnabled, Mode=TwoWay}"
                    Content="{Binding [CameraPage.Rtmp.Toggle], Source={x:Static svc:Localizer.Instance}}"
                    VerticalAlignment="Center"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Margin="0,0,10,0" />
          <TextBox Grid.Column="2"
                   Text="{Binding DraftRtmpUrl, Mode=TwoWay}"
                   PlaceholderText="{Binding [CameraPage.Rtmp.UrlPlaceholder], Source={x:Static svc:Localizer.Instance}}"
                   FontFamily="{StaticResource FontMono}"
                   FontSize="11" />
        </Grid>

        <!-- Action row: night mode + apply + view raw + edit raw. WrapPanel so
             the button cluster wraps on a narrow viewport. -->
        <WrapPanel Orientation="Horizontal" ItemSpacing="8" LineSpacing="8">
          <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
            <Button Content="{Binding [CameraPage.NightMode.Day], Source={x:Static svc:Localizer.Instance}}" Command="{Binding SetNightModeCommand}" CommandParameter="day"
                    Padding="10,4" FontSize="11" Background="{StaticResource Bg3Brush}" Foreground="{StaticResource TextPrimaryBrush}" CornerRadius="4" />
            <Button Content="{Binding [CameraPage.NightMode.Night], Source={x:Static svc:Localizer.Instance}}" Command="{Binding SetNightModeCommand}" CommandParameter="night"
                    Padding="10,4" FontSize="11" Background="{StaticResource Bg3Brush}" Foreground="{StaticResource TextPrimaryBrush}" CornerRadius="4" />
            <Button Content="{Binding [CameraPage.NightMode.Auto], Source={x:Static svc:Localizer.Instance}}" Command="{Binding SetNightModeCommand}" CommandParameter="auto"
                    Padding="10,4" FontSize="11" Background="{StaticResource Bg3Brush}" Foreground="{StaticResource TextPrimaryBrush}" CornerRadius="4" />
          </StackPanel>

          <TextBlock Text="{Binding ApplyStatus}"
                     VerticalAlignment="Center"
                     FontSize="11"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     IsVisible="{Binding ApplyStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

          <Button Content="{Binding [CameraPage.Majestic.ViewRaw], Source={x:Static svc:Localizer.Instance}}"
                  Command="{Binding ToggleRawJsonCommand}"
                  Padding="10,4" FontSize="11"
                  Background="Transparent" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1"
                  CornerRadius="4" Foreground="{StaticResource TextPrimaryBrush}" />
          <Button Content="{Binding [CameraPage.Majestic.AllSettings], Source={x:Static svc:Localizer.Instance}}"
                  Command="{Binding ToggleAllSettingsCommand}"
                  Padding="10,4" FontSize="11"
                  Background="Transparent" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1"
                  CornerRadius="4" Foreground="{StaticResource TextPrimaryBrush}" />
          <Button Content="{Binding [CameraPage.Majestic.Isp], Source={x:Static svc:Localizer.Instance}}"
                  Command="{Binding ToggleIspCommand}"
                  IsVisible="{Binding HasIsp}"
                  Padding="10,4" FontSize="11"
                  Background="Transparent" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1"
                  CornerRadius="4" Foreground="{StaticResource TextPrimaryBrush}" />
          <Button Content="{Binding [CameraPage.Majestic.Metrics], Source={x:Static svc:Localizer.Instance}}"
                  Command="{Binding ToggleMetricsCommand}"
                  Padding="10,4" FontSize="11"
                  Background="Transparent" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1"
                  CornerRadius="4" Foreground="{StaticResource TextPrimaryBrush}" />
          <Button Content="{Binding [CameraPage.Majestic.EditRaw], Source={x:Static svc:Localizer.Instance}}"
                  Command="{Binding EditRawConfigCommand}"
                  IsVisible="{Binding IsRawConfigEditorEnabled}"
                  IsEnabled="{Binding !ApplyInProgress}"
                  Padding="10,4" FontSize="11"
                  Background="Transparent" BorderBrush="{StaticResource WarningBrush}" BorderThickness="1"
                  CornerRadius="4" Foreground="{StaticResource WarningBrush}" />
          <Button Content="{Binding [Common.Apply], Source={x:Static svc:Localizer.Instance}}"
                  Command="{Binding ApplyConfigCommand}"
                  IsEnabled="{Binding !ApplyInProgress}"
                  Padding="14,4" FontSize="11"
                  Background="{StaticResource AccentBrush}" Foreground="White" CornerRadius="4" />
          <!-- SSH fallback for majestic.yaml (Phase 13.5) — advanced opt-in,
               works when the HTTP API is disabled. -->
          <Button Content="{Binding [CameraPage.Majestic.EditRawSsh], Source={x:Static svc:Localizer.Instance}}"
                  Command="{Binding EditMajesticOverSshCommand}"
                  IsVisible="{Binding IsRawConfigEditorEnabled}"
                  IsEnabled="{Binding !ApplyInProgress}"
                  Padding="10,4" FontSize="11"
                  Background="Transparent" BorderBrush="{StaticResource WarningBrush}" BorderThickness="1"
                  CornerRadius="4" Foreground="{StaticResource WarningBrush}" />
        </WrapPanel>

        <!-- Errors -->
        <TextBlock Text="{Binding MajesticError}"
                   FontSize="11"
                   Foreground="{StaticResource DangerBrush}"
                   IsVisible="{Binding MajesticError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

        <!-- Raw JSON viewer (collapsible) -->
        <Border IsVisible="{Binding ShowRawJson}"
                Background="{StaticResource Bg0Brush}"
                BorderBrush="{StaticResource BorderWeakBrush}"
                BorderThickness="1"
                CornerRadius="4"
                MaxHeight="220">
          <ScrollViewer>
            <TextBox Text="{Binding MajesticConfig.RawJson, Mode=OneWay}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="NoWrap"
                     FontFamily="{StaticResource FontMono}"
                     FontSize="11"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="{StaticResource TextSecondaryBrush}" />
          </ScrollViewer>
        </Border>

        <!-- Live ISP panel (Slice C): the isp-section fields, applied on the fly
             without restarting the stream. Same row instances as the All-settings
             editor, so edits stay in sync. -->
        <Border IsVisible="{Binding ShowIsp}"
                Background="{StaticResource Bg0Brush}"
                BorderBrush="{StaticResource BorderWeakBrush}"
                BorderThickness="1"
                CornerRadius="4">
          <StackPanel Spacing="6" Margin="2">
            <ScrollViewer MaxHeight="260" Padding="8">
              <ItemsControl ItemsSource="{Binding IspFields}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid ColumnDefinitions="160,*" Margin="0,1">
                      <TextBlock Grid.Column="0" Text="{Binding Label}"
                                 FontSize="11" VerticalAlignment="Center"
                                 Foreground="{StaticResource TextSecondaryBrush}"
                                 TextTrimming="CharacterEllipsis" />
                      <ToggleSwitch Grid.Column="1"
                                    IsChecked="{Binding BoolValue, Mode=TwoWay}"
                                    IsVisible="{Binding IsBool}"
                                    OnContent="" OffContent=""
                                    HorizontalAlignment="Left" />
                      <ComboBox Grid.Column="1"
                                ItemsSource="{Binding Options}"
                                SelectedItem="{Binding Value, Mode=TwoWay}"
                                IsVisible="{Binding IsCombo}"
                                MinWidth="140" HorizontalAlignment="Left" />
                      <TextBox Grid.Column="1"
                               Text="{Binding Value, Mode=TwoWay}"
                               IsVisible="{Binding IsTextual}"
                               FontFamily="{StaticResource FontMono}"
                               FontSize="11" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
            <Button Content="{Binding [CameraPage.Majestic.IspApply], Source={x:Static svc:Localizer.Instance}}"
                    Command="{Binding ApplyIspLiveCommand}"
                    IsEnabled="{Binding !ApplyInProgress}"
                    Margin="8,0,8,8" HorizontalAlignment="Left"
                    Padding="14,4" FontSize="11"
                    Background="{StaticResource AccentBrush}" Foreground="White" CornerRadius="4" />
          </StackPanel>
        </Border>

        <!-- Schema-driven "All settings" editor (Slice B): every scalar field from
             the live config.json, grouped by section. A superset of the curated
             knobs above; "⟳" flags fields that restart the stream. -->
        <Border IsVisible="{Binding ShowAllSettings}"
                Background="{StaticResource Bg0Brush}"
                BorderBrush="{StaticResource BorderWeakBrush}"
                BorderThickness="1"
                CornerRadius="4">
          <StackPanel Spacing="6" Margin="2">
            <ScrollViewer MaxHeight="320" Padding="8">
              <ItemsControl ItemsSource="{Binding ConfigSections}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <StackPanel Spacing="3" Margin="0,0,0,8">
                      <TextBlock Text="{Binding Header}"
                                 FontWeight="SemiBold" FontSize="11"
                                 Foreground="{StaticResource AccentBrush}"
                                 Margin="0,4,0,2" />
                      <ItemsControl ItemsSource="{Binding Fields}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Grid ColumnDefinitions="160,*" Margin="0,1">
                              <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Label}"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="⟳" FontSize="11"
                                           Foreground="{StaticResource WarningBrush}"
                                           IsVisible="{Binding RequiresRestart}"
                                           ToolTip.Tip="{Binding [CameraPage.Majestic.RestartHint], Source={x:Static svc:Localizer.Instance}}" />
                              </StackPanel>
                              <ToggleSwitch Grid.Column="1"
                                            IsChecked="{Binding BoolValue, Mode=TwoWay}"
                                            IsVisible="{Binding IsBool}"
                                            OnContent="" OffContent=""
                                            HorizontalAlignment="Left" />
                              <ComboBox Grid.Column="1"
                                        ItemsSource="{Binding Options}"
                                        SelectedItem="{Binding Value, Mode=TwoWay}"
                                        IsVisible="{Binding IsCombo}"
                                        MinWidth="140" HorizontalAlignment="Left" />
                              <TextBox Grid.Column="1"
                                       Text="{Binding Value, Mode=TwoWay}"
                                       IsVisible="{Binding IsTextual}"
                                       FontFamily="{StaticResource FontMono}"
                                       FontSize="11" />
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
            <Button Content="{Binding [CameraPage.Majestic.ApplyAll], Source={x:Static svc:Localizer.Instance}}"
                    Command="{Binding ApplyAllSettingsCommand}"
                    IsEnabled="{Binding !ApplyInProgress}"
                    Margin="8,0,8,8" HorizontalAlignment="Left"
                    Padding="14,4" FontSize="11"
                    Background="{StaticResource AccentBrush}" Foreground="White" CornerRadius="4" />
          </StackPanel>
        </Border>

        <!-- Read-only Prometheus metrics (Slice D): name / value pairs from the
             camera's /metrics endpoint, fetched on demand. -->
        <Border IsVisible="{Binding ShowMetrics}"
                Background="{StaticResource Bg0Brush}"
                BorderBrush="{StaticResource BorderWeakBrush}"
                BorderThickness="1"
                CornerRadius="4">
          <StackPanel Spacing="6" Margin="2">
            <Grid ColumnDefinitions="*,Auto" Margin="8,6,8,0">
              <TextBlock Grid.Column="0"
                         Text="{Binding MetricsStatus}"
                         VerticalAlignment="Center" FontSize="11"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         IsVisible="{Binding MetricsStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
              <Button Grid.Column="1"
                      Content="{Binding [CameraPage.Majestic.MetricsRefresh], Source={x:Static svc:Localizer.Instance}}"
                      Command="{Binding LoadMetricsCommand}"
                      Padding="10,4" FontSize="11"
                      Background="Transparent" BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1"
                      CornerRadius="4" Foreground="{StaticResource TextPrimaryBrush}" />
            </Grid>
            <ScrollViewer MaxHeight="280" Padding="8,0,8,8">
              <ItemsControl ItemsSource="{Binding Metrics}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid ColumnDefinitions="*,Auto" Margin="0,1">
                      <TextBlock Grid.Column="0" Text="{Binding Display}"
                                 FontFamily="{StaticResource FontMono}" FontSize="11"
                                 Foreground="{StaticResource TextSecondaryBrush}"
                                 TextTrimming="CharacterEllipsis" />
                      <TextBlock Grid.Column="1" Text="{Binding Value}"
                                 FontFamily="{StaticResource FontMono}" FontSize="11"
                                 Margin="12,0,0,0"
                                 Foreground="{StaticResource TextPrimaryBrush}" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </StackPanel>
        </Border>

      </StackPanel>
    </Border>

    <!-- Bottom bar. Hidden in landscape fullscreen. A WrapPanel so the transport
         controls flow onto extra lines on a phone instead of overflowing the
         6-column row off the right edge. -->
    <WrapPanel Grid.Row="3" Orientation="Horizontal" ItemSpacing="8" LineSpacing="8"
               Margin="0,12,0,0"
               IsVisible="{Binding !IsFullscreen}">

      <!-- REC indicator (visible while recording) -->
      <Border IsVisible="{Binding IsRecording}"
              Background="{StaticResource DangerBrush}"
              CornerRadius="4"
              Padding="8,4"
              VerticalAlignment="Center">
        <TextBlock Text="{Binding RecordingElapsed}"
                   FontFamily="{StaticResource FontMono}"
                   FontSize="11"
                   Foreground="White" />
      </Border>

      <StackPanel Orientation="Horizontal"
                  Spacing="6"
                  IsVisible="{Binding SnapshotPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                  VerticalAlignment="Center">
        <TextBlock Text="{Binding [Snapshot.Saved], Source={x:Static svc:Localizer.Instance}}"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="{StaticResource FontSizeSm}"
                   VerticalAlignment="Center" />
        <Button Content="{Binding [Snapshot.Open], Source={x:Static svc:Localizer.Instance}}"
                Command="{Binding OpenSnapshotCommand}"
                Background="Transparent"
                BorderBrush="{StaticResource BorderMediumBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10,4"
                Foreground="{StaticResource TextPrimaryBrush}" />
        <Button Content="{Binding [Snapshot.Copy], Source={x:Static svc:Localizer.Instance}}"
                Command="{Binding CopySnapshotCommand}"
                Background="Transparent"
                BorderBrush="{StaticResource BorderMediumBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10,4"
                Foreground="{StaticResource TextPrimaryBrush}" />
        <Button Content="{Binding [Snapshot.SaveAs], Source={x:Static svc:Localizer.Instance}}"
                Command="{Binding SaveSnapshotAsCommand}"
                Background="Transparent"
                BorderBrush="{StaticResource BorderMediumBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10,4"
                Foreground="{StaticResource TextPrimaryBrush}" />
      </StackPanel>

      <!-- Audio listen (Phase 17.3): speaker toggle + volume. Shown only when a
           native sink exists AND the camera actually has audio. Muted by default. -->
      <StackPanel Orientation="Horizontal"
                  Spacing="8"
                  VerticalAlignment="Center"
                  IsVisible="{Binding IsAudioControlVisible}">
        <Button Command="{Binding ToggleMuteCommand}"
                Background="Transparent"
                BorderBrush="{StaticResource BorderMediumBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10,8"
                ToolTip.Tip="{Binding [CameraPage.Tooltip.Mute], Source={x:Static svc:Localizer.Instance}}">
          <Panel>
            <Path Classes="lucide" Data="{StaticResource IconVolume}"
                  Stroke="{StaticResource TextPrimaryBrush}" Width="16" Height="16"
                  IsVisible="{Binding !IsMuted}" />
            <Path Classes="lucide" Data="{StaticResource IconVolumeMuted}"
                  Stroke="{StaticResource TextSecondaryBrush}" Width="16" Height="16"
                  IsVisible="{Binding IsMuted}" />
          </Panel>
        </Button>
        <Slider Width="90"
                Minimum="0" Maximum="1"
                Value="{Binding Volume}"
                IsEnabled="{Binding !IsMuted}"
                VerticalAlignment="Center"
                ToolTip.Tip="{Binding [CameraPage.Tooltip.Volume], Source={x:Static svc:Localizer.Instance}}" />
      </StackPanel>

      <!-- Majestic audio-off hint (Phase 17.4): shown instead of the speaker when
           the camera supports audio but has it disabled in config. -->
      <StackPanel Orientation="Horizontal"
                  Spacing="8"
                  VerticalAlignment="Center"
                  IsVisible="{Binding ShowEnableAudioHint}">
        <TextBlock Text="{Binding [CameraPage.Audio.DisabledHint], Source={x:Static svc:Localizer.Instance}}"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="{StaticResource FontSizeSm}"
                   VerticalAlignment="Center" />
        <Button Command="{Binding EnableCameraAudioCommand}"
                IsEnabled="{Binding !EnablingAudio}"
                Background="Transparent"
                BorderBrush="{StaticResource BorderMediumBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10,4"
                Foreground="{StaticResource TextPrimaryBrush}"
                Content="{Binding [CameraPage.Audio.Enable], Source={x:Static svc:Localizer.Instance}}" />
      </StackPanel>

      <!-- Push-to-talk (Phase 17.6): mic → camera speaker. Shown when a mic
           exists; active state highlighted. -->
      <Button x:Name="TalkButton"
              IsVisible="{Binding CanTalk}"
              Background="Transparent"
              BorderBrush="{StaticResource BorderMediumBrush}"
              BorderThickness="1"
              Padding="14,8"
              CornerRadius="6"
              VerticalAlignment="Center"
              ToolTip.Tip="{Binding [CameraPage.Tooltip.Talk], Source={x:Static svc:Localizer.Instance}}">
        <Panel>
          <!-- Accent mic while transmitting, neutral otherwise. -->
          <Path Classes="lucide" Data="{StaticResource IconMic}"
                Stroke="{StaticResource AccentBrush}" Width="16" Height="16"
                IsVisible="{Binding IsTalking}" />
          <Path Classes="lucide" Data="{StaticResource IconMic}"
                Stroke="{StaticResource TextPrimaryBrush}" Width="16" Height="16"
                IsVisible="{Binding !IsTalking}" />
        </Panel>
      </Button>

      <!-- Two-way audio capability hint: shown when the probe found the camera
           advertises no RTSP backchannel, so the missing talk button is explained. -->
      <TextBlock VerticalAlignment="Center"
                 FontSize="11"
                 Opacity="0.7"
                 MaxWidth="180"
                 TextWrapping="Wrap"
                 Foreground="{StaticResource TextPrimaryBrush}"
                 IsVisible="{Binding TwoWayAudioUnsupported}"
                 Text="{Binding [CameraPage.Talk.Unsupported], Source={x:Static svc:Localizer.Instance}}" />

      <Button Command="{Binding ToggleRecordingCommand}"
              IsVisible="{Binding !IsRecording}"
              Background="Transparent"
              BorderBrush="{StaticResource BorderMediumBrush}"
              BorderThickness="1"
              Padding="14,8"
              CornerRadius="6"
              VerticalAlignment="Center"
              Foreground="{StaticResource DangerBrush}"
              Content="● REC" />
      <Button Command="{Binding ToggleRecordingCommand}"
              IsVisible="{Binding IsRecording}"
              Background="{StaticResource DangerBrush}"
              Foreground="White"
              Padding="14,8"
              CornerRadius="6"
              VerticalAlignment="Center"
              Content="{Binding [CameraPage.Stop], Source={x:Static svc:Localizer.Instance}}" />

      <Button Content="{Binding [CameraPage.Snapshot], Source={x:Static svc:Localizer.Instance}}"
              Command="{Binding SnapshotCommand}"
              Background="{StaticResource AccentBrush}"
              Foreground="White"
              Padding="14,8"
              CornerRadius="6"
              VerticalAlignment="Center" />
    </WrapPanel>

  </Grid>

</UserControl>
