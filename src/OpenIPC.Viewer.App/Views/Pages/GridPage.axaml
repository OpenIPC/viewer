<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenIPC.Viewer.App.ViewModels"
             xmlns:controls="using:OpenIPC.Viewer.App.Controls"
             xmlns:conv="using:OpenIPC.Viewer.App.Converters"
             xmlns:svc="using:OpenIPC.Viewer.App.Services"
             xmlns:input="using:Avalonia.Input"
             x:Class="OpenIPC.Viewer.App.Views.Pages.GridPage"
             x:DataType="vm:GridPageViewModel">

  <Grid RowDefinitions="Auto,Auto,*">

    <!-- Toolbar -->
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
      <TextBlock Grid.Column="0"
                 Text="{Binding Title}"
                 FontSize="{StaticResource FontSizeXl}"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource TextPrimaryBrush}"
                 VerticalAlignment="Center" />

      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
        <Button Command="{Binding OpenHealthCommand}"
                Padding="10,6" CornerRadius="6" Margin="0,0,8,0"
                Background="{StaticResource Bg2Brush}"
                BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1"
                ToolTip.Tip="{Binding [Health.Tooltip], Source={x:Static svc:Localizer.Instance}}">
          <Path Classes="lucide" Data="{StaticResource IconActivity}" Stroke="{StaticResource TextPrimaryBrush}" Width="14" Height="14" />
        </Button>
        <Button Content="1×1" Command="{Binding SetLayoutCommand}" CommandParameter="1"
                Padding="10,6" CornerRadius="6"
                Background="{StaticResource Bg2Brush}"
                BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1"
                Foreground="{StaticResource TextPrimaryBrush}" />
        <Button Content="2×2" Command="{Binding SetLayoutCommand}" CommandParameter="2"
                Padding="10,6" CornerRadius="6"
                Background="{StaticResource Bg2Brush}"
                BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1"
                Foreground="{StaticResource TextPrimaryBrush}" />
        <Button Content="3×3" Command="{Binding SetLayoutCommand}" CommandParameter="3"
                Padding="10,6" CornerRadius="6"
                Background="{StaticResource Bg2Brush}"
                BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1"
                Foreground="{StaticResource TextPrimaryBrush}" />
        <Button Content="4×4" Command="{Binding SetLayoutCommand}" CommandParameter="4"
                Padding="10,6" CornerRadius="6"
                Background="{StaticResource Bg2Brush}"
                BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1"
                Foreground="{StaticResource TextPrimaryBrush}" />
        <Button Content="5×5" Command="{Binding SetLayoutCommand}" CommandParameter="5"
                Padding="10,6" CornerRadius="6"
                Background="{StaticResource Bg2Brush}"
                BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1"
                Foreground="{StaticResource TextPrimaryBrush}" />
      </StackPanel>
    </Grid>

    <!-- Layout tabs (Phase 19.1) -->
    <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
      <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding Layouts}" x:CompileBindings="False">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" Spacing="4" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Tapped="OnTabTapped"
                      PointerPressed="OnTabPointerPressed"
                      PointerMoved="OnTabPointerMoved"
                      AttachedToVisualTree="OnTabAttached"
                      input:DragDrop.AllowDrop="True"
                      Cursor="Hand"
                      Padding="12,6" CornerRadius="6"
                      BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1">
                <Border.Background>
                  <MultiBinding Converter="{x:Static conv:LayoutTabBrushConverter.Instance}">
                    <Binding />
                    <Binding Path="DataContext.ActiveLayout" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                  </MultiBinding>
                </Border.Background>
                <TextBlock Text="{Binding Name}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
        <Button Command="{Binding AddLayoutCommand}"
                Content="+" FontSize="16" FontWeight="SemiBold"
                Padding="12,2" CornerRadius="6"
                Background="{StaticResource Bg2Brush}"
                Foreground="{StaticResource TextPrimaryBrush}"
                BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1"
                ToolTip.Tip="{Binding [Layouts.Tooltip.Add], Source={x:Static svc:Localizer.Instance}}" />
        <Button Command="{Binding ManageCamerasCommand}"
                Padding="10,6" CornerRadius="6"
                Background="{StaticResource Bg2Brush}"
                BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1"
                ToolTip.Tip="{Binding [Layouts.Tooltip.Cameras], Source={x:Static svc:Localizer.Instance}}">
          <Path Classes="lucide" Data="{StaticResource IconVideo}" Stroke="{StaticResource TextPrimaryBrush}" Width="14" Height="14" />
        </Button>
        <Button Command="{Binding RenameLayoutCommand}"
                Padding="10,6" CornerRadius="6"
                Background="{StaticResource Bg2Brush}"
                BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1"
                ToolTip.Tip="{Binding [Layouts.Tooltip.Rename], Source={x:Static svc:Localizer.Instance}}">
          <Path Classes="lucide" Data="{StaticResource IconEdit}" Stroke="{StaticResource TextPrimaryBrush}" Width="14" Height="14" />
        </Button>
        <Button Command="{Binding DeleteLayoutCommand}"
                IsEnabled="{Binding CanDeleteLayout}"
                Padding="10,6" CornerRadius="6"
                Background="{StaticResource Bg2Brush}"
                BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1"
                ToolTip.Tip="{Binding [Layouts.Tooltip.Delete], Source={x:Static svc:Localizer.Instance}}">
          <Path Classes="lucide" Data="{StaticResource IconClose}" Stroke="{StaticResource DangerBrush}" Width="14" Height="14" />
        </Button>
      </StackPanel>
    </Grid>

    <!-- Grid -->
    <ItemsControl Grid.Row="2" ItemsSource="{Binding Slots}" x:CompileBindings="False">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <UniformGrid Columns="{Binding Columns}" Rows="{Binding Rows}" />
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <Border Margin="4"
                  Background="{StaticResource Bg0Brush}"
                  CornerRadius="6"
                  ClipToBounds="True"
                  input:DragDrop.AllowDrop="True"
                  AttachedToVisualTree="OnSlotAttached">
            <Grid>
              <!-- Empty placeholder -->
              <Border IsVisible="{Binding ., Converter={x:Static ObjectConverters.IsNull}}"
                      Background="{StaticResource Bg1Brush}">
                <TextBlock Text="{Binding [Grid.EmptySlot], Source={x:Static svc:Localizer.Instance}}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           FontSize="{StaticResource FontSizeSm}" />
              </Border>

              <!-- Tile -->
              <ContentControl Content="{Binding}"
                              IsVisible="{Binding ., Converter={x:Static ObjectConverters.IsNotNull}}">
                <ContentControl.ContentTemplate>
                  <DataTemplate DataType="vm:CameraTileViewModel">
                    <Grid Cursor="Hand"
                          Background="Transparent"
                          Tapped="OnTileTapped"
                          PointerPressed="OnTilePointerPressed"
                          PointerMoved="OnTilePointerMoved">
                      <controls:RtspVideoView Session="{Binding Session}" />

                      <!-- AI detection boxes (Phase 15.5), above the video. -->
                      <controls:DetectionOverlay Detections="{Binding Detections}"
                                                 ShowBoxes="{Binding AnalyticsEnabled}"
                                                 SourceAspect="{Binding SourceAspect}"
                                                 IsHitTestVisible="False" />

                      <!-- Top-left: name -->
                      <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8"
                              Background="#90000000" CornerRadius="3" Padding="6,2">
                        <TextBlock Text="{Binding Name}" Foreground="White" FontSize="13" FontWeight="Medium" />
                      </Border>

                      <!-- Bottom-center: object counter -->
                      <Border HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="8"
                              Background="#90000000" CornerRadius="3" Padding="6,2"
                              IsVisible="{Binding HasDetections}">
                        <TextBlock Text="{Binding DetectionCounter}" Foreground="White" FontSize="11" FontWeight="Medium" />
                      </Border>

                      <!-- Top-right: state badge -->
                      <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8"
                              CornerRadius="3" Padding="6,2"
                              Background="{Binding Status, Converter={x:Static conv:CameraStatusColorConverter.Instance}}">
                        <TextBlock Text="{Binding StateLabel}" Foreground="White"
                                   FontFamily="{StaticResource FontMono}" FontSize="10" />
                      </Border>

                      <!-- Bottom-right: stats (codec • res • fps) -->
                      <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="8"
                              Background="#80000000" CornerRadius="3" Padding="6,2"
                              IsVisible="{Binding HasStats}">
                        <TextBlock Text="{Binding StatsLabel}"
                                   FontFamily="{StaticResource FontMono}" FontSize="10" Foreground="White" />
                      </Border>

                      <!-- Bottom-left: HD snapshot. The tile streams SD, but the
                           service grabs an HD source (Majestic HTTP / brief main). -->
                      <Button HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="8"
                              Command="{Binding SnapshotCommand}"
                              IsVisible="{Binding !IsFailed}"
                              Background="#80000000" CornerRadius="14"
                              Width="28" Height="28" Padding="0"
                              ToolTip.Tip="{Binding [Tile.Snapshot], Source={x:Static svc:Localizer.Instance}}">
                        <Path Classes="lucide" Data="{StaticResource IconCamera}"
                              Stroke="White" Width="16" Height="16" />
                      </Button>

                      <!-- Listen toggle (Phase 17): makes this tile the single
                           audio source. Shown when a native sink exists. -->
                      <Button HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="44,8,8,8"
                              Command="{Binding ToggleListenCommand}"
                              IsVisible="{Binding AudioAvailable}"
                              Background="#80000000" CornerRadius="14"
                              Width="28" Height="28" Padding="0"
                              ToolTip.Tip="{Binding [CameraPage.Tooltip.Listen], Source={x:Static svc:Localizer.Instance}}">
                        <Panel>
                          <Path Classes="lucide" Data="{StaticResource IconVolume}"
                                Stroke="{StaticResource AccentBrush}" Width="16" Height="16"
                                IsVisible="{Binding IsListening}" />
                          <Path Classes="lucide" Data="{StaticResource IconVolumeMuted}"
                                Stroke="White" Width="16" Height="16"
                                IsVisible="{Binding !IsListening}" />
                        </Panel>
                      </Button>

                      <!-- Brief "captured" flash. -->
                      <Border IsVisible="{Binding SnapshotFlash}" Background="#50FFFFFF"
                              IsHitTestVisible="False" />

                      <!-- Connecting / reconnecting dim overlay with spinner. -->
                      <Border IsVisible="{Binding IsConnecting}" Background="#80000000">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                          <ProgressBar IsIndeterminate="True" Width="110" />
                          <TextBlock Text="{Binding ConnectingLabel}"
                                     Foreground="{StaticResource TextSecondaryBrush}"
                                     FontSize="{StaticResource FontSizeSm}"
                                     HorizontalAlignment="Center" />
                        </StackPanel>
                      </Border>

                      <!-- Interactive error cell — reason + Retry / Close. -->
                      <Border IsVisible="{Binding IsFailed}" Background="#A4000000">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Spacing="8" Margin="12" MaxWidth="320">
                          <Path Classes="lucide" Data="{StaticResource IconPlugOff}"
                                Stroke="{StaticResource DangerBrush}" Width="26" Height="26"
                                HorizontalAlignment="Center" />
                          <TextBlock Text="{Binding [Stream.Disconnected], Source={x:Static svc:Localizer.Instance}}"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     FontSize="{StaticResource FontSizeBase}"
                                     FontWeight="Medium"
                                     HorizontalAlignment="Center" />
                          <TextBlock Text="{Binding ErrorDetail}"
                                     Foreground="{StaticResource TextTertiaryBrush}"
                                     FontFamily="{StaticResource FontMono}"
                                     FontSize="11"
                                     TextWrapping="Wrap"
                                     TextAlignment="Center"
                                     HorizontalAlignment="Center" />
                          <StackPanel Orientation="Horizontal" Spacing="8"
                                      HorizontalAlignment="Center" Margin="0,4,0,0">
                            <Button Content="{Binding [Common.Retry], Source={x:Static svc:Localizer.Instance}}"
                                    Command="{Binding RetryCommand}"
                                    Background="{StaticResource AccentBrush}" Foreground="White"
                                    CornerRadius="6" Padding="13,6" FontSize="12" />
                            <Button Content="{Binding [Common.Close], Source={x:Static svc:Localizer.Instance}}"
                                    Command="{Binding CloseCommand}"
                                    Background="Transparent"
                                    BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    CornerRadius="6" Padding="13,6" FontSize="12" />
                          </StackPanel>
                        </StackPanel>
                      </Border>
                    </Grid>
                  </DataTemplate>
                </ContentControl.ContentTemplate>
              </ContentControl>
            </Grid>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

  </Grid>

</UserControl>
