<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenIPC.Viewer.App.ViewModels.Dialogs"
        xmlns:svc="using:OpenIPC.Viewer.App.Services"
        xmlns:dialogs="using:OpenIPC.Viewer.App.Views.Dialogs"
        x:Class="OpenIPC.Viewer.App.Views.Dialogs.ManageLayoutCamerasDialog"
        x:DataType="vm:ManageLayoutCamerasViewModel"
        Title="{Binding [LayoutCameras.WindowTitle], Source={x:Static svc:Localizer.Instance}}"
        Width="480" Height="560"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{StaticResource Bg1Brush}">

  <dialogs:ManageLayoutCamerasContent Name="InnerContent" />

</Window>
