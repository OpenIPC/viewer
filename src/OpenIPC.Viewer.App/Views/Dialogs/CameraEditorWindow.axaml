<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenIPC.Viewer.App.ViewModels.Dialogs"
        xmlns:dialogs="using:OpenIPC.Viewer.App.Views.Dialogs"
        x:Class="OpenIPC.Viewer.App.Views.Dialogs.CameraEditorWindow"
        x:DataType="vm:CameraEditorViewModel"
        Title="{Binding Title}"
        Width="520" Height="640"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{StaticResource Bg1Brush}">

  <dialogs:CameraEditorContent Name="InnerContent" />

</Window>
