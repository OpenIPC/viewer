@* Root document for the server-rendered UI (static SSR — no WASM, no SignalR). *@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>OpenIPC Viewer</title>
    <base href="/" />
    <style>
        /* Console design system — ported from the desktop Themes/Colors.axaml +
           Theme.axaml so the web wears the same skin. */
        :root {
            --bg0:#0a0d11; --bg1:#0f1318; --bg2:#171c24; --bg3:#1f262f;
            --border-weak:#222831; --border-med:#2a323d;
            --text-1:#e4e7ec; --text-2:#8b95a3; --text-3:#5e6878;
            --accent:#5B6CD9; --accent-hover:#7E8DE8; --accent-tint:#1C2658;
            --danger:#ef4444; --warning:#f59e0b; --success:#22c55e;
            --r-sm:6px; --r-md:10px; --r-lg:14px;
            color-scheme: dark;
        }
        * { box-sizing: border-box; }
        body {
            margin:0; background:var(--bg1); color:var(--text-1);
            font-family: Inter, "Segoe UI", system-ui, -apple-system, Roboto, sans-serif;
            font-size:14px; line-height:1.5;
        }
        a { color:var(--accent); text-decoration:none; }
        a:hover { color:var(--accent-hover); text-decoration:underline; }
        h1 { font-size:20px; font-weight:600; margin:0 0 16px; }
        .muted { color:var(--text-2); }
        .err { color:var(--danger); }
        code, .mono { font-family: "Cascadia Code", Consolas, Menlo, monospace; }

        /* App shell: fixed left sidebar + scrolling content, like the desktop. */
        .shell { display:grid; grid-template-columns:216px 1fr; min-height:100vh; }
        .sidebar { background:var(--bg0); border-right:1px solid var(--border-weak);
            display:flex; flex-direction:column; padding:16px 12px; gap:2px; }
        .sidebar .brand { font-weight:600; font-size:16px; padding:6px 10px 18px;
            display:flex; align-items:center; gap:9px; }
        .sidebar .brand .dot { width:16px; height:16px; border-radius:5px; background:var(--accent); display:inline-block; }
        .navitem { display:flex; align-items:center; gap:10px; padding:9px 10px;
            border-radius:var(--r-sm); color:var(--text-2); font-weight:500; }
        .navitem:hover { background:var(--bg2); color:var(--text-1); text-decoration:none; }
        .navitem.active { background:var(--accent-tint); color:var(--text-1); }
        .navitem svg { width:16px; height:16px; flex:none; }
        .sidebar .spacer { flex:1; }
        .sidebar .foot { border-top:1px solid var(--border-weak); margin-top:8px; padding-top:12px;
            font-size:12px; color:var(--text-3); display:flex; flex-direction:column; gap:9px; }
        .sidebar .foot .who { color:var(--text-2); }
        main { padding:24px; overflow:auto; min-width:0; }

        .wrap { max-width:1100px; }
        table { width:100%; border-collapse:collapse; }
        th, td { text-align:left; padding:9px 10px; border-bottom:1px solid var(--border-weak); }
        th { color:var(--text-2); font-weight:500; font-size:11px; text-transform:uppercase; letter-spacing:.04em; }
        tbody tr:hover { background:var(--bg2); }

        input, select, button, textarea {
            font:inherit; padding:8px 10px; border-radius:var(--r-sm);
            border:1px solid var(--border-med); background:var(--bg2); color:var(--text-1);
        }
        input:focus, select:focus { outline:none; border-color:var(--accent); }
        button { cursor:pointer; }
        button:hover { border-color:var(--text-3); }
        button.primary { background:var(--accent); border-color:var(--accent); color:#fff; }
        button.primary:hover { background:var(--accent-hover); border-color:var(--accent-hover); }
        label { display:flex; flex-direction:column; gap:5px; font-size:12px; color:var(--text-2); }
        label input, label select { color:var(--text-1); }

        .badge { font-size:12px; padding:2px 8px; border-radius:var(--r-sm); background:var(--bg3); color:var(--text-2); }
        .badge.on { color:var(--success); }

        .tabs a { display:inline-block; margin-right:8px; padding:6px 13px;
            border:1px solid var(--border-med); border-radius:var(--r-sm); color:var(--text-2); }
        .tabs a:hover { text-decoration:none; color:var(--text-1); }
        .tabs a.active { background:var(--accent); border-color:var(--accent); color:#fff; }

        .videos { display:grid; gap:8px; margin-top:16px; }
        .videos.n1 { grid-template-columns:1fr; }
        .videos.n4 { grid-template-columns:repeat(2,1fr); }
        .videos.n9 { grid-template-columns:repeat(3,1fr); }
        .cell { position:relative; background:#000; border:1px solid var(--border-weak);
            border-radius:var(--r-md); overflow:hidden; aspect-ratio:16/9; }
        .cell video { width:100%; height:100%; object-fit:contain; background:#000; }
        .cell .label { position:absolute; left:8px; bottom:8px; font-size:12px;
            background:rgba(0,0,0,.6); padding:2px 8px; border-radius:var(--r-sm); color:#fff; }
        .cell .empty { display:flex; align-items:center; justify-content:center; height:100%; color:var(--text-3); }

        /* Login: centered card, no sidebar. */
        .login { max-width:340px; margin:12vh auto 0; padding:24px; }
        .login .card { background:var(--bg2); border:1px solid var(--border-weak);
            border-radius:var(--r-lg); padding:28px 24px; }
    </style>
    <HeadOutlet />
    <script>
        // Shared MSE live-tile starter: opens the camera's fMP4/WS stream and
        // plays it in a <video>. Codec is read from the avcC init box so any
        // H.264 profile works. Used by both the single Live page and the grid.
        window.openipcLive = (function () {
            function start(video, id, onStatus) {
                const say = onStatus || function () { };
                if (!('MediaSource' in window)) { say('no MediaSource'); return; }
                const proto = location.protocol === 'https:' ? 'wss' : 'ws';
                let active = null;
                connect(false);

                // transcode=false → copy remux (H.264). If the source turns out to
                // be H.265 (or otherwise unplayable), reconnect once asking the
                // server to re-encode to H.264.
                function connect(transcode) {
                    const url = `${proto}://${location.host}/api/v1/cameras/${id}/live${transcode ? '?transcode=1' : ''}`;
                    const ws = new WebSocket(url);
                    ws.binaryType = 'arraybuffer';
                    active = ws;
                    const ms = new MediaSource();
                    video.src = URL.createObjectURL(ms);
                    let sb = null, queue = [], pending = [], codec = null, msOpen = false, switching = false;
                    ms.addEventListener('sourceopen', () => { msOpen = true; setup(); });
                    say(transcode ? 'transcoding…' : 'connecting');
                    ws.onopen = () => say(transcode ? 'live · transcoded' : 'live');
                    ws.onclose = () => { if (!switching) say('ended'); };
                    ws.onerror = () => say('error');
                    ws.onmessage = e => {
                        const b = new Uint8Array(e.data);
                        if (!sb) {
                            pending.push(b);
                            if (codec === null) codec = findCodec(pending);
                            if (codec === 'hevc' && !transcode) { switching = true; try { ws.close(); } catch { } connect(true); return; }
                            setup(); return;
                        }
                        queue.push(b); pump();
                    };
                    function setup() {
                        if (sb || !msOpen || !codec || codec === 'hevc') return;
                        const mime = `video/mp4; codecs="${codec}"`;
                        if (!MediaSource.isTypeSupported(mime)) {
                            if (!transcode) { switching = true; try { ws.close(); } catch { } connect(true); }
                            else say('unsupported ' + codec);
                            return;
                        }
                        sb = ms.addSourceBuffer(mime); sb.mode = 'segments';
                        sb.addEventListener('updateend', pump);
                        for (const x of pending) queue.push(x); pending = []; pump();
                    }
                    function pump() {
                        if (!sb || sb.updating || !queue.length) return;
                        try { sb.appendBuffer(queue.shift()); } catch (err) { say('buffer error'); }
                        trim();
                    }
                    function trim() {
                        try { if (sb && !sb.updating && sb.buffered.length && video.currentTime > 30) sb.remove(0, video.currentTime - 15); } catch { }
                    }
                }

                // avcC → H.264 codec string; hvcC → 'hevc' sentinel (trigger transcode).
                function findCodec(chunks) {
                    let t = 0; for (const c of chunks) t += c.length;
                    const d = new Uint8Array(t); let o = 0; for (const c of chunks) { d.set(c, o); o += c.length; }
                    for (let i = 0; i + 8 < d.length; i++) {
                        if (d[i] === 0x61 && d[i + 1] === 0x76 && d[i + 2] === 0x63 && d[i + 3] === 0x43)
                            return 'avc1.' + hx(d[i + 5]) + hx(d[i + 6]) + hx(d[i + 7]);
                        if (d[i] === 0x68 && d[i + 1] === 0x76 && d[i + 2] === 0x63 && d[i + 3] === 0x43)
                            return 'hevc';
                    }
                    return null;
                }
                function hx(n) { return n.toString(16).padStart(2, '0').toUpperCase(); }
                return { stop() { try { if (active) active.close(); } catch { } } };
            }
            return { start };
        })();
    </script>
</head>
<body>
    <Routes />
</body>
</html>
