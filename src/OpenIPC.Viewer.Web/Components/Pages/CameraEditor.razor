@page "/app/cameras/new"
@page "/app/cameras/{Id}/edit"
@using OpenIPC.Viewer.Core.Entities
@using OpenIPC.Viewer.Core.Persistence
@using OpenIPC.Viewer.Web.Api
@using OpenIPC.Viewer.Web.Auth
@inject SessionStore Sessions
@inject ICameraRepository CameraRepo
@inject IGroupRepository GroupRepo
@inject NavigationManager Nav
@inject WebLocalizer L

<div class="shell">
<NavSidebar Active="cameras" User="@_user" />
<main>
<div class="wrap" style="max-width:560px">
    <h1>@(IsEdit ? L["Editor.EditTitle"] : L["Editor.AddTitle"])</h1>
    @if (Error is not null)
    {
        <p class="err">@L["Editor.Error"]</p>
    }

    <form method="post" action="@Action">
        <div style="display:flex;flex-direction:column;gap:.7rem">
            <label>@L["Editor.Name"]<input name="name" value="@_cam?.Name" placeholder="Front door" /></label>
            <label>@L["Editor.Host"]<input name="host" value="@_cam?.Host" placeholder="192.168.1.10" /></label>
            <label>@L["Editor.RtspMain"]<input name="rtspMain" value="@_cam?.RtspMain" placeholder="rtsp://192.168.1.10/stream0" /></label>
            <label>@L["Editor.RtspSub"]<input name="rtspSub" value="@_cam?.RtspSub" placeholder="rtsp://192.168.1.10/stream1" /></label>
            <div style="display:flex;gap:.7rem">
                <label style="flex:1">@L["Editor.HttpPort"]<input name="httpPort" type="number" value="@(_cam?.HttpPort ?? 80)" /></label>
                <label style="flex:1">@L["Editor.OnvifPort"]<input name="onvifPort" type="number" value="@_cam?.OnvifPort" placeholder="@L["Editor.Optional"]" /></label>
            </div>
            <label>@L["Editor.Group"]
                <select name="groupId">
                    <option value="">@L["Editor.NoGroup"]</option>
                    @foreach (var g in _groups)
                    {
                        <option value="@g.Id" selected="@(_cam?.GroupId == g.Id)">@g.Name</option>
                    }
                </select>
            </label>
            <label>@L["Editor.Quality"]
                <select name="streamQuality">
                    @foreach (var q in new[] { "Auto", "AlwaysHd", "AlwaysSd" })
                    {
                        <option value="@q" selected="@(string.Equals(_cam?.StreamQuality, q, StringComparison.OrdinalIgnoreCase))">@q</option>
                    }
                </select>
            </label>
            <div style="display:flex;gap:.7rem">
                <label style="flex:1">@L["Editor.Username"]<input name="username" autocomplete="off" placeholder="@(IsEdit ? L["Editor.KeepBlank"] : "admin")" /></label>
                <label style="flex:1">@L["Editor.Password"]<input name="password" type="password" autocomplete="off" placeholder="@(IsEdit ? L["Editor.KeepBlank"] : "")" /></label>
            </div>
            <div style="margin-top:.5rem">
                <button class="primary" type="submit">@(IsEdit ? L["Editor.Save"] : L["Editor.Add"])</button>
                <a href="/app/cameras" style="margin-left:.5rem">@L["Editor.Cancel"]</a>
            </div>
        </div>
    </form>
</div>
</main>
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [CascadingParameter]
    public HttpContext? Http { get; set; }

    private bool IsEdit => Id is not null;
    private string Action => IsEdit ? $"/app/cameras/{Id}/update" : "/app/cameras/create";

    private CameraDto? _cam;
    private List<(int Id, string Name)> _groups = new();
    private string _user = "";

    protected override async Task OnInitializedAsync()
    {
        var token = Http is not null ? AuthApi.CookieToken(Http) : null;
        var identity = token is null ? null : Sessions.Validate(token);
        if (identity is null)
        {
            Nav.NavigateTo("/app/login", forceLoad: false);
            return;
        }
        _user = identity.Name;

        var ct = Http!.RequestAborted;
        _groups = (await GroupRepo.GetAllAsync(ct)).Select(g => (g.Id.Value, g.Name)).ToList();

        if (IsEdit && Guid.TryParse(Id, out var guid))
        {
            var camera = await CameraRepo.GetAsync(new CameraId(guid), ct);
            if (camera is not null)
                _cam = CameraDto.From(camera, null);
        }
    }
}
