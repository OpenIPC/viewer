@page "/app/cameras/{Id}/live"
@inject WebLocalizer L

<div class="wrap">
    <p><a href="/app/cameras">@L["Live.Back"]</a></p>
    <h1>@L["Live.Title"]</h1>
    <video id="v" controls autoplay muted playsinline style="width:100%;max-width:1280px;background:#000;border-radius:8px"></video>
    <p id="status" class="muted"></p>
</div>

<script>
    openipcLive.start(
        document.getElementById('v'),
        "@Id",
        t => { document.getElementById('status').textContent = t; });
</script>

@code {
    [Parameter]
    public string Id { get; set; } = "";
}
