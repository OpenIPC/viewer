@page "/app/cameras/{Id}/live"
@using OpenIPC.Viewer.Web.Auth
@inject SessionStore Sessions
@inject NavigationManager Nav
@inject WebLocalizer L

<div class="shell">
<NavSidebar Active="cameras" User="@_user" />
<main>
<div class="wrap">
    <p><a href="/app/cameras">@L["Live.Back"]</a></p>
    <h1>@L["Live.Title"]</h1>
    <video id="v" controls autoplay muted playsinline style="width:100%;max-width:1280px;background:#000;border-radius:10px;border:1px solid var(--border-weak)"></video>
    <p id="status" class="muted"></p>
</div>
</main>
</div>

<script>
    openipcLive.start(
        document.getElementById('v'),
        "@Id",
        t => { document.getElementById('status').textContent = t; });
</script>

@code {
    [Parameter]
    public string Id { get; set; } = "";

    [CascadingParameter]
    public HttpContext? Http { get; set; }

    private string _user = "";

    protected override void OnInitialized()
    {
        var token = Http is not null ? AuthApi.CookieToken(Http) : null;
        var identity = token is null ? null : Sessions.Validate(token);
        if (identity is null)
            Nav.NavigateTo("/app/login", forceLoad: false);
        else
            _user = identity.Name;
    }
}
