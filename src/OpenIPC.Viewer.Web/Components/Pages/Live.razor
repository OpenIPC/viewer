@page "/app/cameras/{Id}/live"

<div class="wrap">
    <p><a href="/app/cameras">← Cameras</a></p>
    <h1>Live</h1>
    <video id="v" controls autoplay muted playsinline style="width:100%;max-width:1280px;background:#000;border-radius:8px"></video>
    <p id="status" class="muted"></p>
</div>

<script>
    (function () {
        const id = "@Id";
        const statusEl = document.getElementById('status');
        const video = document.getElementById('v');
        const setStatus = t => { statusEl.textContent = t; };

        if (!('MediaSource' in window)) { setStatus('MediaSource not supported by this browser'); return; }

        const proto = location.protocol === 'https:' ? 'wss' : 'ws';
        const ws = new WebSocket(`${proto}://${location.host}/api/v1/cameras/${id}/live`);
        ws.binaryType = 'arraybuffer';

        const ms = new MediaSource();
        video.src = URL.createObjectURL(ms);

        let sb = null, queue = [], pending = [], codec = null, msOpen = false;
        ms.addEventListener('sourceopen', () => { msOpen = true; trySetup(); });
        setStatus('connecting…');

        ws.onopen = () => setStatus('streaming');
        ws.onclose = () => setStatus('stream ended');
        ws.onerror = () => setStatus('connection error');
        ws.onmessage = e => {
            const bytes = new Uint8Array(e.data);
            if (!sb) { pending.push(bytes); if (codec === null) codec = findCodec(pending); trySetup(); return; }
            queue.push(bytes); pump();
        };

        function trySetup() {
            if (sb || !msOpen || !codec) return;
            const mime = `video/mp4; codecs="${codec}"`;
            if (!MediaSource.isTypeSupported(mime)) { setStatus('codec not supported by browser: ' + codec); return; }
            sb = ms.addSourceBuffer(mime);
            sb.mode = 'segments';
            sb.addEventListener('updateend', pump);
            for (const b of pending) queue.push(b);
            pending = [];
            pump();
        }

        function pump() {
            if (!sb || sb.updating || !queue.length) return;
            try { sb.appendBuffer(queue.shift()); }
            catch (err) { setStatus('buffer error: ' + err.message); }
            trimBuffer();
        }

        // Keep the buffered window small so latency doesn't grow unbounded.
        function trimBuffer() {
            try {
                if (sb && !sb.updating && sb.buffered.length && video.currentTime > 30) {
                    sb.remove(0, video.currentTime - 15);
                }
            } catch { /* ignore */ }
        }

        // Read the exact H.264 codec string from the avcC box in the init segment,
        // so any profile/level plays (not just this camera's).
        function findCodec(chunks) {
            let total = 0; for (const c of chunks) total += c.length;
            const d = new Uint8Array(total); let o = 0; for (const c of chunks) { d.set(c, o); o += c.length; }
            for (let i = 0; i + 8 < d.length; i++) {
                if (d[i] === 0x61 && d[i + 1] === 0x76 && d[i + 2] === 0x63 && d[i + 3] === 0x43) { // 'avcC'
                    return 'avc1.' + hex(d[i + 5]) + hex(d[i + 6]) + hex(d[i + 7]);
                }
            }
            return null;
        }
        function hex(n) { return n.toString(16).padStart(2, '0').toUpperCase(); }
    })();
</script>

@code {
    [Parameter]
    public string Id { get; set; } = "";
}
