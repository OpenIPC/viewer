@page "/app/login"
@inject WebLocalizer L

<div class="wrap" style="max-width:340px">
    <h1 style="margin-bottom:.25rem">OpenIPC Viewer</h1>
    <p class="muted" style="margin-top:0">@L["Login.Subtitle"]</p>

    <form method="post" action="/app/auth/login">
        <div style="display:flex;flex-direction:column;gap:.6rem">
            <input name="user" placeholder="@L["Login.Username"]" autocomplete="username" autofocus />
            <input name="password" type="password" placeholder="@L["Login.Password"]" autocomplete="current-password" />
            <button class="primary" type="submit">@L["Login.SignIn"]</button>
        </div>
    </form>

    @if (Error is not null)
    {
        <p class="err">@L["Login.Error"]</p>
    }

    <p class="muted" style="margin-top:1.5rem;font-size:.85rem">
        <a href="/app/lang/en">EN</a> · <a href="/app/lang/ru">RU</a>
    </p>
</div>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }
}
